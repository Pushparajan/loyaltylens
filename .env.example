# ── External APIs ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
HF_TOKEN=hf_...
SAGEMAKER_ENDPOINT=https://runtime.sagemaker.us-east-1.amazonaws.com/endpoints/loyaltylens-prod/invocations

# ── Data Stores ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://loyaltylens:loyaltylens@localhost:5432/loyaltylens
WEAVIATE_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=loyaltylens

# ── Pipeline Tunables ─────────────────────────────────────────────────────────
BATCH_SIZE=512
EVAL_PASS_THRESHOLD=0.75
